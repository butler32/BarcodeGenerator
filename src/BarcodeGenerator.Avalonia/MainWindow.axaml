<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BarcodeGenerator.Avalonia.ViewModels"
        xmlns:views="using:BarcodeGenerator.Avalonia.Views"
        x:Class="BarcodeGenerator.Avalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="BarcodeGenerator — DataMatrix / GS1"
        Width="700" Height="750"
        MinWidth="500" MinHeight="400">

  <TabControl>

    <TabItem>
      <TabItem.Header>
        <StackPanel Orientation="Horizontal" Spacing="2">
          <TextBlock Text="{Binding SingleTabName}" VerticalAlignment="Center"
                     IsVisible="{Binding IsSingleTabRenaming, Converter={x:Static BoolConverters.Not}}" />
          <Button Content="✏" Command="{Binding StartSingleTabRenameCommand}"
                  Padding="3,0" FontSize="10" VerticalAlignment="Center"
                  IsVisible="{Binding IsSingleTabRenaming, Converter={x:Static BoolConverters.Not}}"
                  ToolTip.Tip="Переименовать вкладку" />
          <TextBox Text="{Binding SingleTabName}"
                   BorderThickness="1" Padding="4,1" MinWidth="90" MaxWidth="200"
                   VerticalAlignment="Center"
                   IsVisible="{Binding IsSingleTabRenaming}" />
          <Button Content="✓" Command="{Binding ConfirmSingleTabRenameCommand}"
                  Padding="3,0" FontSize="10" VerticalAlignment="Center"
                  IsVisible="{Binding IsSingleTabRenaming}"
                  ToolTip.Tip="Сохранить название" />
        </StackPanel>
      </TabItem.Header>
      <views:SingleBarcodeView DataContext="{Binding SingleBarcode}" />
    </TabItem>

    <TabItem>
      <TabItem.Header>
        <StackPanel Orientation="Horizontal" Spacing="2">
          <TextBlock Text="{Binding MultiTabName}" VerticalAlignment="Center"
                     IsVisible="{Binding IsMultiTabRenaming, Converter={x:Static BoolConverters.Not}}" />
          <Button Content="✏" Command="{Binding StartMultiTabRenameCommand}"
                  Padding="3,0" FontSize="10" VerticalAlignment="Center"
                  IsVisible="{Binding IsMultiTabRenaming, Converter={x:Static BoolConverters.Not}}"
                  ToolTip.Tip="Переименовать вкладку" />
          <TextBox Text="{Binding MultiTabName}"
                   BorderThickness="1" Padding="4,1" MinWidth="90" MaxWidth="200"
                   VerticalAlignment="Center"
                   IsVisible="{Binding IsMultiTabRenaming}" />
          <Button Content="✓" Command="{Binding ConfirmMultiTabRenameCommand}"
                  Padding="3,0" FontSize="10" VerticalAlignment="Center"
                  IsVisible="{Binding IsMultiTabRenaming}"
                  ToolTip.Tip="Сохранить название" />
        </StackPanel>
      </TabItem.Header>
      <views:MultiBarcodesView DataContext="{Binding MultiBarcodes}" />
    </TabItem>

    <TabItem>
      <TabItem.Header>
        <StackPanel Orientation="Horizontal" Spacing="2">
          <TextBlock Text="{Binding SeriesTabName}" VerticalAlignment="Center"
                     IsVisible="{Binding IsSeriesTabRenaming, Converter={x:Static BoolConverters.Not}}" />
          <Button Content="✏" Command="{Binding StartSeriesTabRenameCommand}"
                  Padding="3,0" FontSize="10" VerticalAlignment="Center"
                  IsVisible="{Binding IsSeriesTabRenaming, Converter={x:Static BoolConverters.Not}}"
                  ToolTip.Tip="Переименовать вкладку" />
          <TextBox Text="{Binding SeriesTabName}"
                   BorderThickness="1" Padding="4,1" MinWidth="90" MaxWidth="200"
                   VerticalAlignment="Center"
                   IsVisible="{Binding IsSeriesTabRenaming}" />
          <Button Content="✓" Command="{Binding ConfirmSeriesTabRenameCommand}"
                  Padding="3,0" FontSize="10" VerticalAlignment="Center"
                  IsVisible="{Binding IsSeriesTabRenaming}"
                  ToolTip.Tip="Сохранить название" />
        </StackPanel>
      </TabItem.Header>
      <views:SeriesGeneratorView DataContext="{Binding SeriesGenerator}" />
    </TabItem>

  </TabControl>

</Window>
